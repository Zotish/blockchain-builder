{
  "name": "chainforge-backend",
  "version": "1.0.0",
  "description": "ChainForge - Blockchain Builder Platform Backend",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "seed": "node src/config/seed.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true
  },
  "dependencies": {
    "@sentry/node": "^10.50.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dockerode": "^5.0.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.23.1",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "node-ssh": "^13.2.1",
    "nodemailer": "^8.0.7",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
