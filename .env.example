# ChainForge Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB (optional - using in-memory storage by default)
MONGO_URI=mongodb://localhost:27017/chainforge

# JWT
JWT_SECRET=chainforge-super-secret-key-change-in-production
JWT_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Payment Wallet (change to your wallet address)
PAYMENT_WALLET=0x742d35Cc6634C0532925a3b844Bc9e7595f2bD38

# Blockchain RPCs (for payment verification)
ETH_RPC=https://mainnet.infura.io/v3/YOUR_KEY
BSC_RPC=https://bsc-dataseed.binance.org
POLYGON_RPC=https://polygon-rpc.com
